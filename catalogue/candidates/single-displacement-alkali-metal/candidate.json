  "premises": [
    {
      "id": "premise.rule.alkali-metal-activity-series.standard-outcome",
      "statement": "A more reactive alkali metal displaces a less reactive alkali metal from its halide salt, following the reviewed group 1 reactivity trend K > Na > Li: member(s) + displaced-X -> member-X + displaced(s), a single electron transfer from the displacing metal to the displaced metal's cation followed by ionic re-association. This is a theoretical simulation of the activity-series displacement principle (see docs/safety.md's virtual-educational-model framing), not a recommended real-world aqueous bench procedure; alkali metals also react with water, a confound this package does not model or claim to avoid.",
      "evidence": ["evidence.openstax.chemistry-2e.activity-series"],
      "review": {"status": "provisional", "reviewers": []},
      "rule_version": "1"
    },
    {
      "id": "premise.valence.activity-series.initial-domain",
      "statement": "The listed Li, Na, K, Cl, Br, I, and F tuples, including the transient monatomic radical intermediate shared by metallic release and metallic join, are the closed valence domain for alkali-metal single-displacement chemistry.",
      "evidence": ["evidence.openstax.chemistry-2e.activity-series"],
      "review": {"status": "provisional", "reviewers": []},
      "rule_version": "1"
    },
    {
      "id": "premise.observation.displaced-metal-forms",
      "statement": "The displaced elemental alkali metal is compatible with the authored observation predicate forms for this family outcome.",
      "evidence": ["evidence.openstax.chemistry-2e.activity-series"],
      "review": {"status": "provisional", "reviewers": []},
      "rule_version": "1"
    },
    {
