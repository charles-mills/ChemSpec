  "premises": [
    {
      "id": "premise.category.halide",
      "statement": "ChemSpec explicitly bounds this educational halide parameter to F, Cl, Br, and I; At and Ts are outside the modeled domain and no chemistry is inferred for them.",
      "evidence": [
        "evidence.chemspec.explanatory-structural-model"
      ],
      "review": {
        "status": "provisional",
        "reviewers": []
      },
      "rule_version": "1"
    },
    {
      "id": "premise.structure.silver-nitrate",
      "statement": "ChemSpec represents silver nitrate as an ionic assembly of an Ag+ cation and a covalently bonded NO3- anion using one canonical Lewis structure: one N=O double bond and two N-O single bonds carrying the -1 formal charges.",
      "evidence": [
        "evidence.chemspec.explanatory-structural-model"
      ],
      "review": {
        "status": "provisional",
        "reviewers": []
      },
      "rule_version": "1"
    },
    {
      "id": "premise.structure.alkali-metal-halide",
      "statement": "ChemSpec represents each supported alkali-metal halide as an ionic association of an M+ cation and a monatomic X- anion.",
      "evidence": [
        "evidence.chemspec.explanatory-structural-model"
      ],
      "review": {
        "status": "provisional",
        "reviewers": []
      },
      "rule_version": "1"
    },
    {
      "id": "premise.structure.alkali-metal-nitrate",
      "statement": "ChemSpec represents each supported alkali-metal nitrate as an ionic association of an M+ cation and the same NO3- anion structure as silver nitrate.",
      "evidence": [
        "evidence.chemspec.explanatory-structural-model"
      ],
      "review": {
        "status": "provisional",
        "reviewers": []
      },
      "rule_version": "1"
    },
    {
      "id": "premise.structure.silver-halide",
      "statement": "ChemSpec represents each supported silver halide precipitate as an ionic association of an Ag+ cation and a monatomic X- anion.",
      "evidence": [
        "evidence.chemspec.explanatory-structural-model"
      ],
      "review": {
        "status": "provisional",
        "reviewers": []
      },
      "rule_version": "1"
    },
    {
      "id": "premise.rule.silver-halide-precipitation.standard-outcome",
      "statement": "Mixing aqueous silver nitrate with an aqueous sodium chloride, bromide, or iodide has the reviewed representative outcome AgNO3 + NaX -> AgX (precipitate) + NaNO3, a pure ionic re-association with no covalent bond or electron change.",
      "evidence": [
        "evidence.chemspec.explanatory-structural-model",
        "evidence.openstax.chemistry-2e.solubility"
      ],
      "review": {
        "status": "provisional",
        "reviewers": []
      },
      "rule_version": "1"
    },
    {
      "id": "premise.case.silver-fluoride-unsupported",
      "statement": "Silver fluoride is soluble in water rather than an insoluble precipitate, so the standard silver-halide precipitation outcome does not extend to X = F; representing soluble-salt exceptions to a precipitation family is outside the current structural domain.",
      "evidence": [
        "evidence.openstax.chemistry-2e.solubility"
      ],
      "review": {
        "status": "provisional",
        "reviewers": []
      },
      "rule_version": "1"
    },
    {
      "id": "premise.valence.precipitation.initial-domain",
      "statement": "The listed Ag, N, O, Na, Cl, Br, and I tuples are ChemSpec's closed explanatory execution domain for silver-halide precipitation; they are not a claim of physical mechanism.",
      "evidence": [
        "evidence.chemspec.explanatory-structural-model"
      ],
      "review": {
