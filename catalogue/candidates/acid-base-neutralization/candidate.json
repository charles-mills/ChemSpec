    {
      "id": "premise.rule.acid-base-neutralization.standard-outcome",
      "statement": "Mixing an aqueous strong monoprotic hydrogen halide acid with an aqueous alkali-metal hydroxide has the reviewed representative outcome HX + MOH -> MX + H2O, a proton transfer from the acid to the hydroxide oxygen followed by ionic association of the conserved cation and halide.",
      "evidence": ["evidence.chemspec.explanatory-structural-model", "evidence.openstax.chemistry-2e.acid-base"],
      "review": {"status": "provisional", "reviewers": []},
      "rule_version": "1"
    },
    {
      "id": "premise.case.hydrofluoric-acid-unsupported",
      "statement": "Hydrofluoric acid is a weak acid that only partially dissociates in water, which is a different equilibrium reaction model from the full, one-step strong-acid dissociation this family represents; representing partial-dissociation equilibria is outside the current structural domain.",
      "evidence": ["evidence.openstax.chemistry-2e.acid-base"],
      "review": {"status": "provisional", "reviewers": []},
      "rule_version": "1"
    },
    {
      "id": "premise.valence.acid-base.initial-domain",
      "statement": "The listed H, O, Li, Na, K, Cl, Br, F, and I tuples are ChemSpec's closed explanatory execution domain for monoprotic acid / alkali-metal hydroxide neutralization; transient states are not claims of physical mechanism.",
      "evidence": ["evidence.chemspec.explanatory-structural-model"],
      "review": {"status": "provisional", "reviewers": []},
      "rule_version": "1"
    },
    {
      "id": "premise.observation.acid-disappears",
