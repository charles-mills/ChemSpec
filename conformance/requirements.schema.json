{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chemspec.dev/schema/conformance-requirements-1.json",
  "title": ".chems specification requirement registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "specification", "requirements"],
  "properties": {
    "schema_version": { "const": 1 },
    "specification": { "type": "string", "minLength": 1 },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "section", "component"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z]{3,4}-[0-9]{3}$" },
          "section": { "type": "string", "minLength": 1 },
          "occurrence": { "type": "integer", "minimum": 1, "default": 1 },
          "component": { "type": "string", "pattern": "^[a-z]+(?:-[a-z]+)*$" }
        }
      }
    }
  }
}
