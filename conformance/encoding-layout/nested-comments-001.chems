chems 1
use catalog ChemSpec.Structural@1
reaction Comments where
  /- outer /- nested -/ comment -/
  reactants
    water := 1 of Water -- trailing
  products
    waterProduct := 1 of Water
  equation
    H2O[molecular] -> H2O[molecular]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.Comments@1
    -- leading observation comment
    product waterProduct forms claim R1
  by
    apply Rules.Identity
      input := water
