{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chemspec.dev/schema/conformance-manifest-1.json",
  "title": ".chems conformance manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "requirements", "components", "cases"],
  "properties": {
    "schema_version": { "const": 1 },
    "requirements": { "const": "conformance/requirements.json" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "fixture_directory", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z]+(?:-[a-z]+)*$" },
          "fixture_directory": { "type": "string", "pattern": "^conformance/[a-z]+(?:-[a-z]+)*$" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "component", "requirements", "expected"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z]+(?:-[a-z]+)*-[0-9]{3}$" },
          "component": { "type": "string" },
          "requirements": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "input": { "type": "string" },
          "source": { "type": "string" },
          "catalogue": { "type": "string" },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state"],
            "properties": {
              "state": {
                "enum": [
                  "malformed",
                  "ill-typed",
                  "incomplete",
                  "invalid",
                  "unsupported",
                  "validated-with-assumptions",
                  "validated",
                  "system-error"
                ]
              },
              "diagnostics": {
                "type": "array",
                "default": [],
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["code", "severity", "primary_span"],
                  "properties": {
                    "code": { "type": "string", "pattern": "^CHEMS-[LPTCKFI][0-9]{3}$" },
                    "severity": { "enum": ["Error", "Warning", "Information"] },
                    "primary_span": { "$ref": "#/$defs/span" },
                    "related_spans": {
                      "type": "array",
                      "default": [],
                      "items": { "$ref": "#/$defs/span" }
                    }
                  }
                }
              },
              "domain": { "type": "string" },
              "formatted_source": { "type": "string" },
              "cst_sha256": { "type": "string" },
              "ast_sha256": { "type": "string" },
              "ast": { "type": "string" },
              "hir": { "type": "string" },
              "derivation": { "type": "string" },
              "artifact": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture", "start", "end"],
      "properties": {
        "fixture": { "type": "string" },
        "start": { "type": "integer", "minimum": 0 },
        "end": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
