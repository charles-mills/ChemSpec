chems 1
use catalog ChemSpec.Structural@1
reaction FormatMe where
  reactants
    -- retained reactant
    water := 1 of Water
  products
    waterProduct := 1 of Water -- retained trailing
  equation
    H2O[molecular] -> H2O[molecular]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.FormatMe@1
    product waterProduct forms claim R1
  by
    apply Rules.Identity
      input := water
