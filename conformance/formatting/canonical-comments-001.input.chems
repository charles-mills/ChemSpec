chems   1
use catalog ChemSpec.Aqueous@1
experiment Demo where
  conditions
    -- medium follows
    medium:=aqueous
    pressure:=1   atm -- room pressure
    temperature:=25.00 degC
  given
    water:=10 mL of H2O(l)
  vessels
    beaker:=open vessel 100 mL
  procedure
    place water in beaker
  model
    event := representative
    sequence := explanatory
    structuralRule := ChemSpec.Structural.Test.Comments
  expect
    /- authored hole -/
    class:=?
  by
    close
