chems 1
use catalog ChemSpec.Theoretical@1
reaction ZrAndOxygenToTransitionG4DioxideWithOzone where
  reactants
    subject := 3 of ZrTransitionG4DioxideMetalForOxygen
    oxygen := 2 of Ozone
  products
    oxide := 3 of ZrTransitionG4DioxideOxide
  equation
    3 Zr[metallic] + 2 O3[molecular]
    -> 3 ZrO2[ionic]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.OxygenReaction@1
    product oxide forms claim R1
    reactant subject disappears claim R2
  by
    apply Rules.OzoneTransitionG4Dioxide
      subject := subject
      oxygen := oxygen
      oxide := oxide
