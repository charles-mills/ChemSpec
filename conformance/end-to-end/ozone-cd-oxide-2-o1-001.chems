chems 1
use catalog ChemSpec.Theoretical@1
reaction CdAndOxygenToTransitionG12MonoxideWithOzone where
  reactants
    subject := 6 of CdTransitionG12MonoxideMetalForOxygen
    oxygen := 2 of Ozone
  products
    oxide := 6 of CdTransitionG12MonoxideOxide
  equation
    6 Cd[metallic] + 2 O3[molecular]
    -> 6 CdO[ionic]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.OxygenReaction@1
    product oxide forms claim R1
    reactant subject disappears claim R2
  by
    apply Rules.OzoneTransitionG12Monoxide
      subject := subject
      oxygen := oxygen
      oxide := oxide
