chems 1
use catalog ChemSpec.Theoretical@1
reaction MgAndSulfide where
  reactants
    cation := 8 of MgFixedCation2Metal
    anion := 1 of ElementalSulfur
  products
    salt := 8 of MgFixedCation2Sulfide
  equation
    8 Mg[metallic] + 1 S8[molecular]
    -> 8 MgS[ionic]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.IonPairReaction@1
    product salt forms claim R1
    reactant cation disappears claim R2
  by
    apply Rules.FixedCation2Sulfide
      cation := cation
      anion := anion
      salt := salt
