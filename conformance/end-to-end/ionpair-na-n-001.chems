chems 1
use catalog ChemSpec.Theoretical@1
reaction NaAndNitride where
  reactants
    cation := 6 of NaFixedCation1Metal
    anion := 1 of ElementalNitrogen
  products
    salt := 2 of NaFixedCation1Nitride
  equation
    6 Na[metallic] + 1 N2[molecular]
    -> 2 Na3N[ionic]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.IonPairReaction@1
    product salt forms claim R1
    reactant cation disappears claim R2
  by
    apply Rules.FixedCation1Nitride
      cation := cation
      anion := anion
      salt := salt
