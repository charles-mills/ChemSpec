chems 1
use catalog ChemSpec.Theoretical@1
reaction BrF5FromElements where
  reactants
    central := 1 of Bromine
    ligand := 5 of Fluorine
  products
    compound := 2 of InterhalogenBrF5
  equation
    1 Br2[molecular] + 5 F2[molecular]
    -> 2 BrF5[molecular]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.CovalentCombination@1
    product compound forms claim R1
    reactant ligand disappears claim R2
  by
    apply Rules.Interhalogen5Combination
      central := central
      ligand := ligand
      compound := compound
