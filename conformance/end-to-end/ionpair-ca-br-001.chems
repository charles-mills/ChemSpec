chems 1
use catalog ChemSpec.Theoretical@1
reaction CaAndBromide where
  reactants
    cation := 1 of CaFixedCation2Metal
    anion := 1 of ElementalBromine
  products
    salt := 1 of CaFixedCation2Bromide
  equation
    1 Ca[metallic] + 1 Br2[molecular]
    -> 1 CaBr2[ionic]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.IonPairReaction@1
    product salt forms claim R1
    reactant cation disappears claim R2
  by
    apply Rules.FixedCation2Bromide
      cation := cation
      anion := anion
      salt := salt
