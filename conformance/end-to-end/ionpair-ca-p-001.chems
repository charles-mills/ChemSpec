chems 1
use catalog ChemSpec.Theoretical@1
reaction CaAndPhosphide where
  reactants
    cation := 6 of CaFixedCation2Metal
    anion := 1 of ElementalPhosphorus
  products
    salt := 2 of CaFixedCation2Phosphide
  equation
    6 Ca[metallic] + 1 P4[molecular]
    -> 2 Ca3P2[ionic]
  model
    event := representative
    sequence := explanatory
  observe from Evidence.IonPairReaction@1
    product salt forms claim R1
    reactant cation disappears claim R2
  by
    apply Rules.FixedCation2Phosphide
      cation := cation
      anion := anion
      salt := salt
