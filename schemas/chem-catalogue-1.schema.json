{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chemspec.dev/schema/chem-catalogue-1.json",
  "title": "ChemSpec structural catalogue envelope schema 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["digest", "bundle"],
  "properties": {
    "digest": {"$ref": "#/$defs/digest"},
    "bundle": {"$ref": "#/$defs/bundle"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]+$"},
    "nonempty": {"type": "string", "minLength": 1},
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "name", "version", "publication", "created", "evidence", "premises", "valence_premises", "structures", "rules"],
      "properties": {
        "schema_version": {"const": 1},
        "name": {"$ref": "#/$defs/nonempty"},
        "version": {"$ref": "#/$defs/nonempty"},
        "publication": {"enum": ["working", "production"]},
        "created": {"$ref": "#/$defs/created"},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
        "premises": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/premise"}},
        "valence_premises": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/valencePremise"}},
        "structures": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/structure"}},
        "rules": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/rule"}}
      }
    },
    "created": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_on", "created_by"],
      "properties": {
        "created_on": {"$ref": "#/$defs/date"},
        "created_by": {"$ref": "#/$defs/nonempty"},
        "notes": {"type": "string"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "publisher", "locator", "reference", "retrieved_on", "usage"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"$ref": "#/$defs/nonempty"},
        "publisher": {"$ref": "#/$defs/nonempty"},
        "locator": {"$ref": "#/$defs/nonempty"},
        "reference": {"$ref": "#/$defs/nonempty"},
        "publication_date": {"$ref": "#/$defs/date"},
        "retrieved_on": {"$ref": "#/$defs/date"},
        "usage": {"$ref": "#/$defs/nonempty"}
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "reviewed_on", "reference"],
      "properties": {
        "reviewer": {"$ref": "#/$defs/nonempty"},
        "reviewed_on": {"$ref": "#/$defs/date"},
        "reference": {"$ref": "#/$defs/nonempty"},
        "notes": {"type": "string"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {"enum": ["reviewed", "provisional", "rejected"]},
        "reviewers": {"type": "array", "items": {"$ref": "#/$defs/reviewer"}}
      }
    },
    "premise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "evidence", "review", "rule_version"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "statement": {"$ref": "#/$defs/nonempty"},
        "evidence": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "review": {"$ref": "#/$defs/review"},
        "rule_version": {"$ref": "#/$defs/nonempty"}
      }
    },
    "valencePremise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["premise_id", "neutral_valence", "supported_states"],
      "properties": {
        "premise_id": {"$ref": "#/$defs/id"},
        "neutral_valence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/elementValence"}},
        "supported_states": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/valenceState"}},
        "metallic_domain_states": {"type": "array", "items": {"$ref": "#/$defs/metallicValence"}}
      }
    },
    "elementValence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element", "neutral_valence_electrons"],
      "properties": {
        "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"},
        "neutral_valence_electrons": {"type": "integer", "minimum": 1, "maximum": 255}
      }
    },
    "valenceState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element", "formal_charge", "non_bonding_electrons", "unpaired_electrons", "covalent_bond_order_sum"],
      "properties": {
        "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"},
        "formal_charge": {"type": "integer", "minimum": -32768, "maximum": 32767},
        "non_bonding_electrons": {"type": "integer", "minimum": 0, "maximum": 255},
        "unpaired_electrons": {"type": "integer", "minimum": 0, "maximum": 255},
        "covalent_bond_order_sum": {"type": "integer", "minimum": 0, "maximum": 255}
      }
    },
    "metallicValence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element", "site_formal_charge", "site_local_electrons", "delocalized_electrons_per_site"],
      "properties": {
        "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"},
        "site_formal_charge": {"type": "integer", "minimum": -32768, "maximum": 32767},
        "site_local_electrons": {"type": "integer", "minimum": 0, "maximum": 255},
        "delocalized_electrons_per_site": {"type": "integer", "minimum": 1, "maximum": 4294967295}
      }
    },
    "atom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "element", "formal_charge", "non_bonding_electrons", "unpaired_electrons"],
      "properties": {
        "label": {"$ref": "#/$defs/id"},
        "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"},
        "formal_charge": {"type": "integer", "minimum": -32768, "maximum": 32767},
        "non_bonding_electrons": {"type": "integer", "minimum": 0, "maximum": 255},
        "unpaired_electrons": {"type": "integer", "minimum": 0, "maximum": 255}
      }
    },
    "bond": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "right", "order"],
      "properties": {
        "left": {"$ref": "#/$defs/id"},
        "right": {"$ref": "#/$defs/id"},
        "order": {"enum": ["single", "double", "triple"]}
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "atoms"],
      "properties": {
        "label": {"$ref": "#/$defs/id"},
        "atoms": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "structure": {
      "oneOf": [
        {"$ref": "#/$defs/covalentStructure"},
        {"$ref": "#/$defs/ionicStructure"},
        {"$ref": "#/$defs/metallicStructure"}
      ]
    },
    "covalentStructure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "premise_id", "formula", "representation", "atoms"],
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "premise_id": {"$ref": "#/$defs/id"}, "formula": {"$ref": "#/$defs/nonempty"},
        "representation": {"enum": ["molecular", "ion"]},
        "atoms": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom"}},
        "bonds": {"type": "array", "items": {"$ref": "#/$defs/bond"}},
        "groups": {"type": "array", "items": {"$ref": "#/$defs/group"}}
      }
    },
    "component": {
      "type": "object", "additionalProperties": false, "required": ["label", "atoms"],
      "properties": {
        "label": {"$ref": "#/$defs/id"}, "atoms": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom"}},
        "bonds": {"type": "array", "items": {"$ref": "#/$defs/bond"}}, "groups": {"type": "array", "items": {"$ref": "#/$defs/group"}}
      }
    },
    "ionicStructure": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "premise_id", "formula", "representation", "components", "associations"],
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "premise_id": {"$ref": "#/$defs/id"}, "formula": {"$ref": "#/$defs/nonempty"}, "representation": {"const": "ionic"},
        "components": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/component"}},
        "associations": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["label", "components"], "properties": {"label": {"$ref": "#/$defs/id"}, "components": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}}}}
      }
    },
    "metallicStructure": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "premise_id", "formula", "representation", "sites", "domains"],
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "premise_id": {"$ref": "#/$defs/id"}, "formula": {"$ref": "#/$defs/nonempty"}, "representation": {"const": "metallic"},
        "sites": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom"}},
        "domains": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["label", "sites", "delocalized_electrons"], "properties": {"label": {"$ref": "#/$defs/id"}, "sites": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "delocalized_electrons": {"type": "integer", "minimum": 1, "maximum": 4294967295}}}}
      }
    },
    "pattern": {
      "type": "object", "additionalProperties": false, "required": ["role", "structure_id", "coefficient"],
      "properties": {"role": {"$ref": "#/$defs/id"}, "structure_id": {"$ref": "#/$defs/id"}, "coefficient": {"type": "integer", "minimum": 1, "maximum": 4294967295}}
    },
    "electronState": {"type": "array", "prefixItems": [{"type": "integer", "minimum": -32768, "maximum": 32767}, {"type": "integer", "minimum": 0, "maximum": 255}, {"type": "integer", "minimum": 0, "maximum": 255}], "minItems": 3, "maxItems": 3},
    "binaryState": {
      "type": "object", "additionalProperties": false, "required": ["left", "right"],
      "properties": {"left": {"$ref": "#/$defs/electronState"}, "right": {"$ref": "#/$defs/electronState"}}
    },
    "transferState": {
      "type": "object", "additionalProperties": false, "required": ["donor", "acceptor"],
      "properties": {"donor": {"$ref": "#/$defs/electronState"}, "acceptor": {"$ref": "#/$defs/electronState"}}
    },
    "metallicState": {
      "type": "object", "additionalProperties": false, "required": ["site", "domain_electrons"],
      "properties": {"site": {"$ref": "#/$defs/electronState"}, "domain_electrons": {"type": "integer", "minimum": 0, "maximum": 4294967295}}
    },
    "cleavageAllocation": {
      "oneOf": [
        {"const": "homolytic"},
        {"type": "object", "additionalProperties": false, "required": ["heterolytic_to"], "properties": {"heterolytic_to": {"$ref": "#/$defs/nonempty"}}}
      ]
    },
    "operation": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "edge", "allocation", "before", "after"],
          "properties": {
            "kind": {"const": "cleave_covalent"},
            "edge": {"type": "array", "prefixItems": [{"$ref": "#/$defs/nonempty"}, {"$ref": "#/$defs/nonempty"}, {"enum": ["single", "double", "triple"]}], "minItems": 3, "maxItems": 3},
            "allocation": {"$ref": "#/$defs/cleavageAllocation"}, "before": {"$ref": "#/$defs/binaryState"}, "after": {"$ref": "#/$defs/binaryState"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "edge", "electron_contribution", "before", "after"],
          "properties": {
            "kind": {"const": "form_covalent"},
            "edge": {"type": "array", "prefixItems": [{"$ref": "#/$defs/nonempty"}, {"$ref": "#/$defs/nonempty"}, {"enum": ["single", "double", "triple"]}], "minItems": 3, "maxItems": 3},
            "electron_contribution": {"type": "object", "additionalProperties": false, "required": ["left", "right"], "properties": {"left": {"type": "integer", "minimum": 0, "maximum": 255}, "right": {"type": "integer", "minimum": 0, "maximum": 255}}},
            "before": {"$ref": "#/$defs/binaryState"}, "after": {"$ref": "#/$defs/binaryState"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "edge", "old_order", "new_order", "allocation", "before", "after"],
          "properties": {
            "kind": {"const": "change_covalent"},
            "edge": {"type": "array", "prefixItems": [{"$ref": "#/$defs/nonempty"}, {"$ref": "#/$defs/nonempty"}], "minItems": 2, "maxItems": 2},
            "old_order": {"enum": ["single", "double", "triple"]}, "new_order": {"enum": ["single", "double", "triple"]},
            "allocation": {"$ref": "#/$defs/cleavageAllocation"}, "before": {"$ref": "#/$defs/binaryState"}, "after": {"$ref": "#/$defs/binaryState"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "label", "components", "component_charges"],
          "properties": {
            "kind": {"const": "associate_ionic"}, "label": {"$ref": "#/$defs/id"},
            "components": {"type": "array", "minItems": 2, "items": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}}},
            "component_charges": {"type": "array", "minItems": 2, "items": {"type": "integer", "minimum": -32768, "maximum": 32767}}
          }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["kind", "association"],
          "properties": {"kind": {"const": "dissociate_ionic"}, "association": {"$ref": "#/$defs/nonempty"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "site", "domain", "allocation", "before", "after"],
          "properties": {"kind": {"const": "release_metallic"}, "site": {"$ref": "#/$defs/nonempty"}, "domain": {"$ref": "#/$defs/nonempty"}, "allocation": {"enum": ["retain_electron", "leave_electron"]}, "before": {"$ref": "#/$defs/metallicState"}, "after": {"$ref": "#/$defs/metallicState"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "site", "domain", "allocation", "before", "after"],
          "properties": {"kind": {"const": "join_metallic"}, "site": {"$ref": "#/$defs/nonempty"}, "domain": {"$ref": "#/$defs/nonempty"}, "allocation": {"const": "donate_electron"}, "before": {"$ref": "#/$defs/metallicState"}, "after": {"$ref": "#/$defs/metallicState"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "count", "donor", "acceptor", "before", "after"],
          "properties": {"kind": {"const": "transfer_electron"}, "count": {"type": "integer", "minimum": 1, "maximum": 255}, "donor": {"$ref": "#/$defs/nonempty"}, "acceptor": {"$ref": "#/$defs/nonempty"}, "before": {"$ref": "#/$defs/transferState"}, "after": {"$ref": "#/$defs/transferState"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "atoms", "product"],
          "properties": {"kind": {"const": "assign_product"}, "atoms": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}}, "product": {"$ref": "#/$defs/nonempty"}}
        }
      ]
    },
    "rule": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "premise_ids", "roles", "reactant_pattern", "product_pattern", "applicability", "mapping_template", "operation_template", "model_assumptions", "observation_compatibility"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "premise_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "roles": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object", "additionalProperties": false, "required": ["side", "representation"], "properties": {"side": {"enum": ["reactant", "product"]}, "representation": {"enum": ["molecular", "ion", "ionic", "metallic"]}}}},
        "reactant_pattern": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/pattern"}},
        "product_pattern": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/pattern"}},
        "applicability": {"type": "object", "additionalProperties": false, "required": ["premise_id", "request_relation", "reactant_structure_ids", "required_context"], "properties": {"premise_id": {"$ref": "#/$defs/id"}, "request_relation": {"const": "contact"}, "reactant_structure_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "required_context": {"$ref": "#/$defs/nonempty"}}},
        "mapping_template": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["reactant", "product"], "properties": {"reactant": {"$ref": "#/$defs/nonempty"}, "product": {"$ref": "#/$defs/nonempty"}}}},
        "operation_template": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/operation"}},
        "model_assumptions": {"type": "object", "additionalProperties": false, "required": ["event", "sequence"], "properties": {"event": {"const": "representative"}, "sequence": {"const": "explanatory"}}},
        "observation_compatibility": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["subject_role", "predicate", "evidence_subject", "premise_id"], "properties": {"subject_role": {"$ref": "#/$defs/id"}, "predicate": {"enum": ["evolves", "disappears", "forms", "colour"]}, "evidence_subject": {"$ref": "#/$defs/nonempty"}, "value": {"$ref": "#/$defs/nonempty"}, "premise_id": {"$ref": "#/$defs/id"}}}}
      }
    }
  }
}
