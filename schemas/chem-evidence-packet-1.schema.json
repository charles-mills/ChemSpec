{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chemspec.dev/schema/chem-evidence-packet-1.json",
  "title": "ChemSpec external evidence packet schema 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "claims", "sources"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9_:-]+(?:\\.[A-Za-z0-9_:-]+)*@[0-9]+(?:\\.[0-9]+)*$" },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "subject_role", "subject", "predicate", "sources"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
          "subject_role": { "$ref": "#/$defs/nonblank" },
          "subject": { "$ref": "#/$defs/nonblank" },
          "predicate": { "enum": ["evolves", "disappears", "forms", "colour"] },
          "sources": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "publisher", "url", "supports"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
          "title": { "$ref": "#/$defs/nonblank" },
          "publisher": { "$ref": "#/$defs/nonblank" },
          "url": { "$ref": "#/$defs/nonblank" },
          "supports": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
          }
        }
      }
    }
  },
  "$defs": {
    "nonblank": { "type": "string", "pattern": "\\S" }
  }
}
