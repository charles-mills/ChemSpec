{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chemspec.dev/schema/chem-catalogue-review-1.json",
  "title": "ChemSpec external catalogue review attestation schema 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "catalogue_digest",
    "reviewer",
    "reviewed_on",
    "scope",
    "method",
    "sources",
    "premises",
    "coverage_conclusion",
    "limitation"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "catalogue_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "reviewer": { "type": "string", "minLength": 1 },
    "reviewed_on": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "scope": { "type": "string", "minLength": 1 },
    "method": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
    },
    "premises": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
    },
    "coverage_conclusion": { "type": "string", "minLength": 1 },
    "limitation": { "type": "string", "minLength": 1 }
  }
}
